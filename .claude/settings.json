{
  "statusLine": {
    "type": "command",
    "command": "bash \"$CLAUDE_PROJECT_DIR/templates/hooks/statusline.sh\""
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/templates/hooks/context-watchdog.sh\" \"$TOOL_NAME\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/templates/hooks/implementation-health.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/templates/hooks/session-review-hook.sh\""
          }
        ]
      }
    ]
  }
}
